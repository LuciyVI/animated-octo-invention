BOT_TOKEN=
ADMIN_IDS=111111111,222222222

# Local panel API URL.
# If panel root path is "/", use:
XUI_HOST=http://127.0.0.1:54321/

# If panel root path is "/secret-path/", use:
# XUI_HOST=http://127.0.0.1:54321/secret-path/

# Create token in 3x-ui:
# Settings -> Security -> API Token
XUI_TOKEN=

PUBLIC_HOST=vpn.example.com

# Telegram group access gate.
REQUIRE_GROUP_MEMBERSHIP=true
ACCESS_GROUP_ID=
GROUP_MEMBERSHIP_CACHE_TTL_SEC=300

# Automatic inbound provisioning.
AUTO_PROVISION_INBOUND=true
TEMPLATE_INBOUND_REMARK=Moroz
TEMPLATE_INBOUND_ID=

PORT_MIN=30000
PORT_MAX=39999
MAX_INBOUNDS_PER_TG_ID=1
MAX_CONFIGS_PER_INBOUND=5

DEFAULT_ACCESS_DAYS=30
DEFAULT_CLIENT_TRAFFIC_GB=0

# User permissions.
USER_CAN_MANAGE_OWN_INBOUND=true
USER_CAN_DISABLE_OWN_CLIENTS=true
USER_CAN_DISABLE_OWN_INBOUND=false
# Dangerous: lets users update their own inbound core fields through confirmed JSON flow.
# Keep false unless you understand that port/protocol/streamSettings/TLS/REALITY changes can break access.
USER_CAN_CHANGE_INBOUND_CORE_SETTINGS=false

# Optional: disable user configs when user leaves access group.
DISABLE_ACCESS_WHEN_LEFT_GROUP=false

# Technical output.
SHOW_TECHNICAL_IDS_TO_USERS=false
DEBUG_CALLBACKS=false

DB_PATH=./bot.db

# Legacy self-service access creation. Prefer AUTO_PROVISION_INBOUND for the current model.
SELF_SERVICE_CREATE_ACCESS=false
SELF_SERVICE_TEMPLATE_INBOUND_ID=
